{
  "manifest_version": 3,
  "name": "Grok Gallery Manager",
  "version": "1.0.0",
  "description": "File-manager-style gallery for AI-generated images and videos from Grok Imagine",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://x.com/grok*",
    "https://*.twimg.com/*",
    "https://*.xai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://x.com/grok*"
      ],
      "js": ["content.js"],
      "css": ["sidecar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
